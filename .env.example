# 墨宇戰情中樞 MOYU OPS — env 範例
#
# 用法:
#   cp .env.example .env.local
#   填入實際值
#   生產值在 Zeabur dashboard
#
# 注意:
#   - 不要 commit .env.local(.gitignore 已擋)
#   - NEXT_PUBLIC_* 會 expose 到 client side bundle
#   - 其他都是 server-side 才看得到

# ───── Supabase (3) ─────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# ───── LINE (6) ─────
LINE_CHANNEL_ACCESS_TOKEN=               # Messaging API push / reply (Bot)
LINE_CHANNEL_SECRET=                     # webhook signature 驗證
LINE_LOGIN_CHANNEL_ID=                   # LINE Login OAuth(Channel ID,網頁登入)
LINE_LOGIN_CHANNEL_SECRET=               # LINE Login OAuth Secret
LINE_ADMIN_USER_ID=                      # 系統事件推這個 UID 給 Vincent(LINE userId)
NEXT_PUBLIC_LINE_BASIC_ID=@494rhwya      # 前端顯示官方帳號連結(@id)

# ───── Google (4) ─────
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=      # Multi-line: "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_JSON_B64=         # 某些路由用 base64 JSON 整包(擇一)
RECRUIT_SHARED_CALENDAR_ID=              # 招聘共享行事曆(Google Calendar ID)

# ───── AI (3) ─────
ANTHROPIC_API_KEY=                       # 主力:戰情官 / knowledge bot / 通話評估
OPENAI_API_KEY=                          # RAG embeddings(text-embedding-3-small)
GROQ_API_KEY=                            # Whisper Large v3 通話轉錄

# ───── Metabase (3) — 後台 admin endpoint 直接 query 用 ─────
# 注意:GitHub Actions metabase-daily-sync workflow 已 cache session 進 system_secrets,
#       後台 lib/metabase.ts 自動讀 cache,所以這 3 個 env 通常不必填
#       (留 fallback 給「session expire 且 GH workflow 還沒跑」的 edge case)
METABASE_HOST=https://mb.kolable.com
METABASE_USER=
METABASE_PASS=

# ───── 應用層 (3) ─────
CRON_SECRET=                             # cron route 驗 Bearer header
NEXT_PUBLIC_APP_URL=https://moyusales.zeabur.app   # 主 URL(前後端共用)
PUBLIC_APP_URL=                          # legacy,會 fallback 到 NEXT_PUBLIC_APP_URL,可不填
NEXT_PUBLIC_SITE_URL=https://moyusales.zeabur.app  # 部分 SEO meta 用

# ───── Notion(1) — RAG ingest ─────
NOTION_INTEGRATION_TOKEN=                # internal integration token(讀 Notion DB)

# ───── Discord(2) — OAuth 登入 ─────
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=

# ───── Error tracking(1) — 2026-04-30 第三輪加 ─────
SENTRY_DSN=                              # https://{key}@{host}/{project_id};沒設則 lib/error-tracker noop

# ───── 開發只需 ─────
NODE_ENV=development                     # production 在 Zeabur 自動設
