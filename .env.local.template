# 本機跑 scripts/whisper-batch-all.mjs 用的 .env.local 範本
# cp .env.local.template .env.local 然後填以下 3 個 key
#
# 注意:.env.local 已在 .gitignore,不會 commit 到 git

# Groq API key(Whisper Large v3 用)
# 取得:https://console.groq.com/keys
GROQ_API_KEY=

# Supabase 主機 URL(已 public,從 Zeabur env 複製或 Supabase dashboard 拿)
# 例:https://nqegeidvsflkwllnfink.supabase.co
SUPABASE_URL=

# Supabase service_role key(可 bypass RLS,從 Supabase dashboard Settings → API 拿)
# 警告:此 key 不可進前端 / 不可 commit / 不可印 log
SUPABASE_SERVICE_ROLE_KEY=
